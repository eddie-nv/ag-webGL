# Copy this file to .env (which is gitignored) and fill in real values.
#
# The Python agent uses python-dotenv to auto-load .env at startup,
# and Next.js auto-loads .env into process.env.

# --- LLM (M8 e2e + production) ---
# Pick ONE provider. Anthropic (claude-opus-4-7) is the project default.
ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...

# --- Backend ---
# Frontend (CopilotKit route) talks to the Python agent via this URL.
# Default works for local dev; override for staging/prod.
SCENE_AGENT_URL=http://localhost:8000/agui
